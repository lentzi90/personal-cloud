{
  "extends": ["config:recommended"],
  "hostRules": [
    { "matchHost": "index.docker.io", "token": "{{ secrets.token }}" }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^longhorn/base/kustomization.yaml$/"],
      "matchStrings": [
        "longhorn\\/longhorn\\/(?<currentValue>.*?)\\/deploy\\/longhorn.yaml\\n"
      ],
      "depNameTemplate": "longhorn/longhorn",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^argocd/bases/sopsSecretGenerator/kustomization.yaml$/"
      ],
      "matchStrings": ["SOPS_SECRET_GENERATOR_VERSION=(?<currentValue>.*?)\\n"],
      "depNameTemplate": "goabout/kustomize-sopssecretgenerator",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^argocd/bases/sopsSecretGenerator/kustomization.yaml$/"
      ],
      "matchStrings": ["SOPS_VERSION=(?<currentValue>.*?)\\n"],
      "depNameTemplate": "mozilla/sops",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^argocd/bases/sopsSecretGenerator/kustomization.yaml$/"
      ],
      "matchStrings": ["YQ_VERSION=(?<currentValue>.*?)\\n"],
      "depNameTemplate": "mikefarah/yq",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^apps/kind/envoy-gateway-app.yaml$/",
        "/^turing-talos/apps/envoy-gateway-app.yaml$/"
      ],
      "matchStrings": ["targetRevision: (?<currentValue>.*?)\\n"],
      "depNameTemplate": "envoyproxy/gateway",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^cert-manager/base/kustomization.yaml$/"],
      "matchStrings": [
        "download\\/(?<currentValue>.*?)\\/cert-manager.yaml\\n"
      ],
      "depNameTemplate": "cert-manager/cert-manager",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^external-secrets/base/kustomization.yaml$/"],
      "matchStrings": [
        "download\\/(?<currentValue>.*?)\\/external-secrets.yaml\\n"
      ],
      "depNameTemplate": "external-secrets/external-secrets",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^keycloak-operator/base/kustomization.yaml$/"],
      "matchStrings": [
        "keycloak-k8s-resources\\/(?<currentValue>.*?)\\/kubernetes.*.yml\\n"
      ],
      "depNameTemplate": "keycloak/keycloak-k8s-resources",
      "datasourceTemplate": "github-tags"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^prometheus/base/prometheus.yaml$/"],
      "matchStrings": ["version: (?<currentValue>.*?)\\n"],
      "depNameTemplate": "prometheus/prometheus",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^cloudnative-pg/base/kustomization.yaml$/"],
      "matchStrings": ["download\\/(?<currentValue>.*?)\\/cnpg-.*.yaml\\n"],
      "autoReplaceStringTemplate": "download/{{{prettyNewVersion}}}/cnpg-{{{newVersion}}}.yaml\\n",
      "depNameTemplate": "cloudnative-pg/cloudnative-pg",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^external-secrets/components/bitwarden-sdk-server/deployment.yaml$/"
      ],
      "matchStrings": ["bitwarden-sdk-server:(?<currentValue>.*?)\""],
      "depNameTemplate": "external-secrets/bitwarden-sdk-server",
      "datasourceTemplate": "github-releases"
    }
  ],
  "packageRules": [{ "matchCategories": ["docker"], "enabled": false }]
}
